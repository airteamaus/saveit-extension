{
  "manifest_version": 3,
  "name": "Newtab Bookmarks",
  "version": "1.27.1",
  "description": "Save web pages and rediscover them with AI-powered metadata and search",
  "key": "",
  "browser_specific_settings": {
    "gecko": {
      "id": "saveit@airteam.com.au",
      "data_collection_permissions": {
        "required": [
          "browsingActivity"
        ]
      }
    }
  },
  "permissions": [
    "activeTab",
    "alarms",
    "bookmarks",
    "notifications",
    "scripting",
    "storage",
    "identity"
  ],
  "host_permissions": [
    "https://saveit-5pu7ljvnuq-uc.a.run.app/*",
    "https://saveit-realtime-5pu7ljvnuq-uc.a.run.app/*",
    "https://saveit-staging-5pu7ljvnuq-uc.a.run.app/*"
  ],
  "background": {
    "scripts": [
      "src/bundles/background-bundle.js"
    ],
    "service_worker": "src/bundles/background-bundle.js",
    "type": "module"
  },
  "action": {
    "default_icon": {
      "16": "src/icon-16.png",
      "32": "src/icon-32.png",
      "48": "src/icon-48.png",
      "128": "src/icon-128.png"
    },
    "default_popup": "src/toolbar-popup.html"
  },
  "chrome_url_overrides": {
    "newtab": "src/newtab.html"
  },
  "icons": {
    "16": "src/icon-16.png",
    "32": "src/icon-32.png",
    "48": "src/icon-48.png",
    "128": "src/icon-128.png"
  }
}
