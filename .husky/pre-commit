echo "🔍 Running pre-commit checks..."

# Run linter
echo "  → Linting..."
pnpm run lint || {
  echo "❌ Linting failed. Run 'pnpm run lint:fix' to fix issues."
  exit 1
}

# Lint CSS
echo "  → Linting CSS..."
pnpm run lint:css || {
  echo "❌ CSS linting failed. Run 'pnpm run lint:css:fix' to fix issues."
  exit 1
}

# Check formatting
echo "  → Checking formatting..."
pnpm run format:check || {
  echo "❌ Formatting check failed. Run 'pnpm run format' to fix."
  exit 1
}

# Validate manifest (uses same exclusions as pnpm run validate)
echo "  → Validating manifest..."
pnpm run validate || {
  echo "❌ Manifest validation failed (warnings OK for now)."
  # Don't fail on warnings - web-ext lint has many false positives
  true
}

# Run tests
echo "  → Running tests..."
pnpm test || {
  echo "❌ Tests failed. Fix tests before committing."
  exit 1
}

# Check for console.log in production code (warning only)
if git diff --cached --name-only | grep -E '\.(js)$' | xargs grep -n "console\.log" 2>/dev/null | grep -v "console.error" | grep -v "test\.js" | grep -v "mock-data\.js"; then
  echo "⚠️  Warning: console.log statements found. Consider removing for production."
fi

echo "✅ Pre-commit checks passed!"
